# Per-box config. Copy to `.env` next to docker-compose.yml on the box:
#
#   cp .env.example .env
#
# .env is gitignored — these values describe one machine, not the project.

# REQUIRED. How many concurrent tables this box is allowed to host — the
# server refuses to boot without it (prod would crash-loop). Set it from
# measurement, not vibes: run the load test against this box
# (`npm run loadtest`, see server/src/loadtest.ts) and use the highest
# stage where the sim rate holds ~60. 50 is a conservative starting guess.
MAX_LOBBIES=50
